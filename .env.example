# データベース（Prisma / Supabase PostgreSQL）
DATABASE_URL=
DIRECT_URL=

# microCMS（ブログ）
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# お問合せフォームのメール送信（Resend）
RESEND_API_KEY=
# 送信元アドレス。ドメイン認証前は onboarding@resend.dev でテスト可
RESEND_FROM_EMAIL=CAFORA <onboarding@resend.dev>
# 問合せ通知の受信先（店舗の受信箱）
SHOP_EMAIL=

# Google Analytics 4 測定ID（G-XXXXXXX）
# 本番のみ計測するため、Vercel では Production スコープにのみ登録すること。
# Preview / ローカルでは未設定にしておく（GAタグが出力されない）。
NEXT_PUBLIC_GA_ID=
